DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.mativiglianco.cloud
CORS_ALLOWED_ORIGINS=https://api.mativiglianco.cloud,https://vales.mativiglianco.cloud,https://mativiglianco.github.io
